#!/bin/bash
set -o pipefail

# hpc-reconnect — Full automated reconnect pipeline:
#   1. Check/establish EduVPN
#   2. Submit SLURM job (if none running)
#   3. Wait for node allocation
#   4. Establish SSH tunnels
#
# Config: ~/.config/hpc-tunnel.conf (connection settings)
#         ~/.config/hpc-tunnel.env   (credentials, never committed)

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
CONF="$HOME/.config/hpc-tunnel.conf"
ENV_FILE="$HOME/.config/hpc-tunnel.env"

# ─── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'

step()  { echo -e "\n${CYAN}[$1/$STEPS]${NC} $2"; }
ok()    { echo -e "  ${GREEN}✓${NC} $1"; }
warn()  { echo -e "  ${YELLOW}!${NC} $1"; }
fail()  { echo -e "  ${RED}✗${NC} $1"; }

# ─── Load config ─────────────────────────────────────────────
if [ ! -f "$CONF" ]; then
    echo "Error: $CONF not found. Run install.sh first."
    exit 1
fi
source "$CONF"

if [ -f "$ENV_FILE" ]; then
    source "$ENV_FILE"
fi

STEPS=4

# ─── Step 1: VPN ─────────────────────────────────────────────
step 1 "Checking VPN..."

vpn_status() {
    # eduvpn-cli exits 2 even when connected; ignore its exit code
    local out
    out=$(eduvpn-cli status 2>/dev/null) || true
    echo "$out" | grep -q "Connected"
}

vpn_remaining() {
    local out
    out=$(eduvpn-cli status 2>/dev/null) || true
    echo "$out" | grep "Valid for" | sed 's/.*Valid for: //'
}

if vpn_status; then
    ok "VPN connected ($(vpn_remaining) remaining)"
else
    warn "VPN not connected — attempting reconnect..."

    # Disconnect to clear stale state, then reconnect
    eduvpn-cli disconnect >/dev/null 2>&1
    sleep 1

    # Create URL capture script
    URL_FILE=$(mktemp)
    CAPTURE_SCRIPT=$(mktemp)
    cat > "$CAPTURE_SCRIPT" << CAPTUREEOF
#!/bin/bash
echo "\$@" > "$URL_FILE"
CAPTUREEOF
    chmod +x "$CAPTURE_SCRIPT"

    # Connect with BROWSER capture — silent refresh if token valid,
    # otherwise captures the auth URL for Playwright
    # -n 1 = reconnect to server #1 (first configured server)
    BROWSER="$CAPTURE_SCRIPT" eduvpn-cli connect -n 1 >/dev/null 2>&1 &
    CONNECT_PID=$!

    # Wait: either VPN comes up (silent) or URL appears (needs browser)
    AUTH_URL=""
    for i in $(seq 1 15); do
        if vpn_status; then break; fi
        if [ -s "$URL_FILE" ]; then
            AUTH_URL=$(cat "$URL_FILE")
            break
        fi
        sleep 1
    done

    rm -f "$CAPTURE_SCRIPT"

    if vpn_status; then
        kill $CONNECT_PID 2>/dev/null || true
        rm -f "$URL_FILE"
        ok "VPN reconnected via refresh token"
    elif [ -n "$AUTH_URL" ]; then
        # Refresh token expired — need browser auth
        warn "Browser auth needed — launching Playwright..."

        if [ -z "$IDP_USER" ] || [ -z "$IDP_PASS" ]; then
            fail "IDP_USER and IDP_PASS not set in $ENV_FILE"
            echo "  Add your IdP credentials to $ENV_FILE:"
            echo "    IDP_USER=youruser"
            echo "    IDP_PASS=yourpassword"
            kill $CONNECT_PID 2>/dev/null || true
            rm -f "$URL_FILE"
            exit 1
        fi

        echo "  Auth URL: ${AUTH_URL:0:80}..."
        rm -f "$URL_FILE"

        # Run Playwright to complete the Shibboleth login
        PLAYWRIGHT_SCRIPT="$SCRIPT_DIR/eduvpn-auth.js"
        if [ ! -f "$PLAYWRIGHT_SCRIPT" ]; then
            PLAYWRIGHT_SCRIPT="$HOME/.local/share/hpc-reconnect/eduvpn-auth.js"
        fi

        NODE_PATH="$HOME/.local/share/hpc-reconnect/node_modules" \
        AUTH_URL="$AUTH_URL" IDP_USER="$IDP_USER" IDP_PASS="$IDP_PASS" \
            node "$PLAYWRIGHT_SCRIPT" 2>&1

        # Wait for eduvpn-cli to finish token exchange + WireGuard setup
        echo "  Waiting for VPN tunnel..."
        for i in $(seq 1 45); do
            if vpn_status; then break; fi
            sleep 2
        done

        kill $CONNECT_PID 2>/dev/null || true
        wait $CONNECT_PID 2>/dev/null || true

        if vpn_status; then
            ok "VPN authenticated via browser automation"
        else
            fail "VPN auth failed. Debug screenshot at /tmp/eduvpn-auth-debug.png"
            exit 1
        fi
    else
        # Neither connected nor got a URL
        kill $CONNECT_PID 2>/dev/null || true
        rm -f "$URL_FILE"
        fail "VPN failed — no connection and no auth URL captured"
        exit 1
    fi
fi

# ─── Step 2: Check HPC reachability ─────────────────────────
step 2 "Checking HPC access..."

if ! ssh -o ConnectTimeout=15 -o BatchMode=yes "$HPC_JUMP" "echo ok" >/dev/null 2>&1; then
    fail "Cannot reach jump host ($HPC_JUMP). VPN may not be fully up yet."
    exit 1
fi
ok "Jump host reachable"

# ─── Step 3: SLURM job ──────────────────────────────────────
step 3 "Checking SLURM job..."

JOB_SCRIPT="${SLURM_JOB_SCRIPT:-}"
if [ -z "$JOB_SCRIPT" ]; then
    # Default: look for common locations
    JOB_SCRIPT=$(ssh -o ConnectTimeout=10 "$HPC_JUMP" \
        "ls -t ~/qwen_1day.sh ~/job.sh ~/run.sh 2>/dev/null | head -1")
fi

# Check for an existing running job
EXISTING=$(ssh -o ConnectTimeout=10 "$HPC_JUMP" \
    "squeue -u \$USER -h -o '%i %T %N' 2>/dev/null" | head -1)

if [ -n "$EXISTING" ]; then
    JOB_ID=$(echo "$EXISTING" | awk '{print $1}')
    JOB_STATE=$(echo "$EXISTING" | awk '{print $2}')
    JOB_NODE=$(echo "$EXISTING" | awk '{print $3}')

    if [ "$JOB_STATE" = "RUNNING" ] && [ -n "$JOB_NODE" ]; then
        ok "Job $JOB_ID already running on $JOB_NODE"
    elif [ "$JOB_STATE" = "PENDING" ]; then
        ok "Job $JOB_ID is pending — waiting for allocation..."
        JOB_NODE=""
    else
        warn "Job $JOB_ID in state: $JOB_STATE"
    fi
else
    # No running job — submit one
    if [ -z "$JOB_SCRIPT" ]; then
        fail "No running job and SLURM_JOB_SCRIPT not set in config."
        echo "  Set SLURM_JOB_SCRIPT in $CONF or $ENV_FILE"
        exit 1
    fi

    echo "  Submitting: sbatch $JOB_SCRIPT"
    SUBMIT_OUTPUT=$(ssh -o ConnectTimeout=10 "$HPC_JUMP" "sbatch $JOB_SCRIPT 2>&1")
    JOB_ID=$(echo "$SUBMIT_OUTPUT" | grep -oP '\d+' | tail -1)

    if [ -z "$JOB_ID" ]; then
        fail "sbatch failed: $SUBMIT_OUTPUT"
        exit 1
    fi
    ok "Submitted job $JOB_ID"
    JOB_NODE=""
fi

# Poll for node allocation if not yet running
if [ -z "$JOB_NODE" ]; then
    echo "  Waiting for node allocation..."
    for i in $(seq 1 120); do
        POLL=$(ssh -o ConnectTimeout=10 "$HPC_JUMP" \
            "squeue -j $JOB_ID -h -o '%T %N' 2>/dev/null" | head -1)
        STATE=$(echo "$POLL" | awk '{print $1}')
        NODE=$(echo "$POLL" | awk '{print $2}')

        if [ "$STATE" = "RUNNING" ] && [ -n "$NODE" ]; then
            JOB_NODE="$NODE"
            ok "Job running on $JOB_NODE (waited ${i}0s)"
            break
        fi

        # Show progress every 30s
        if (( i % 3 == 0 )); then
            echo "  ... still waiting (${i}0s, state: ${STATE:-UNKNOWN})"
        fi
        sleep 10
    done

    if [ -z "$JOB_NODE" ]; then
        fail "Timed out waiting for job allocation (20 min)"
        exit 1
    fi
fi

# ─── Step 4: Establish tunnels ───────────────────────────────
step 4 "Setting up tunnels to $JOB_NODE..."

# Use hpc-node to switch
HPC_NODE_CMD="$HOME/.local/bin/hpc-node"
if [ -x "$HPC_NODE_CMD" ]; then
    "$HPC_NODE_CMD" "$JOB_NODE"
else
    # Fallback: update config and restart services manually
    sed -i "s/^HPC_NODE=.*/HPC_NODE=${JOB_NODE}/" "$CONF"
    if grep -q "^Host hpc$" "$HOME/.ssh/config" 2>/dev/null; then
        sed -i "/^Host hpc$/,/^Host /{s/^\(\s*HostName\s\).*/\1${JOB_NODE}/}" "$HOME/.ssh/config"
    fi
    systemctl --user restart hpc-tunnel-forward
    sleep 3
    systemctl --user restart hpc-tunnel-reverse 2>/dev/null || true
fi

# ─── Verify ──────────────────────────────────────────────────
echo ""
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo -e "${GREEN}  HPC pipeline ready${NC}"
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo "  Node:  $JOB_NODE"
echo "  Job:   $JOB_ID"
source "$CONF"
echo "  LLM:   localhost:$LLM_PORT"
echo "  ASR:   localhost:$ASR_PORT"
echo "  TTS:   localhost:$TTS_PORT"
if [ -n "$WORKSTATION" ]; then
    echo "  Workstation: $WORKSTATION (reverse tunnel)"
fi
echo ""
