#!/bin/bash
# hpc-status — Machine-readable status for AI agents
# All output is JSON. Exit code 0 = healthy, 1 = degraded, 2 = down.
#
# Usage:
#   hpc-status              Full status (JSON)
#   hpc-status --services   Just service health
#   hpc-status --tunnel     Just tunnel status
#   hpc-status --vpn        Just VPN status
#   hpc-status --job        Just SLURM job info

CONF="$HOME/.config/hpc-tunnel.conf"
[ -f "$CONF" ] && source "$CONF"

json_kv() { printf '"%s":"%s"' "$1" "$2"; }
json_kvn() { printf '"%s":%s' "$1" "$2"; }

# ─── VPN Status ──────────────────────────────────────────────
vpn_json() {
    local status="disconnected" remaining=""
    local raw=$(eduvpn-cli status 2>/dev/null)
    if echo "$raw" | grep -q "Connected"; then
        status="connected"
        remaining=$(echo "$raw" | grep "Valid for" | sed 's/.*Valid for: //')
    fi
    printf '{%s,%s}' "$(json_kv status "$status")" "$(json_kv remaining "$remaining")"
}

# ─── Tunnel Status ───────────────────────────────────────────
tunnel_json() {
    local fwd="inactive" rev="inactive"
    systemctl --user is-active hpc-tunnel-forward >/dev/null 2>&1 && fwd="active"
    systemctl --user is-active hpc-tunnel-reverse >/dev/null 2>&1 && rev="active"

    local ports="[]"
    if [ -n "$FORWARD_PORTS" ]; then
        ports="["
        local first=true
        IFS=',' read -ra PAIRS <<< "$FORWARD_PORTS"
        for pair in "${PAIRS[@]}"; do
            lp=$(echo "$pair" | cut -d: -f1)
            rp=$(echo "$pair" | cut -d: -f2)
            $first || ports+=","
            ports+="{\"local\":$lp,\"remote\":$rp}"
            first=false
        done
        ports+="]"
    fi

    printf '{%s,%s,%s,%s}' \
        "$(json_kv forward "$fwd")" \
        "$(json_kv reverse "$rev")" \
        "$(json_kv node "$HPC_NODE")" \
        "$(json_kvn ports "$ports")"
}

# ─── SLURM Job Status ───────────────────────────────────────
job_json() {
    local job_data='{"running":false}'
    if [ -n "$HPC_JUMP" ]; then
        local raw=$(ssh -o ConnectTimeout=10 -o BatchMode=yes "$HPC_JUMP" \
            "squeue -u \$USER -h -o '%i|%T|%N|%P|%M|%j' 2>/dev/null" 2>/dev/null | head -1)
        if [ -n "$raw" ]; then
            IFS='|' read -r jid state node part time name <<< "$raw"
            job_data=$(printf '{"running":true,"id":"%s","state":"%s","node":"%s","partition":"%s","elapsed":"%s","name":"%s"}' \
                "$jid" "$state" "$node" "$part" "$time" "$name")
        fi
    fi
    echo "$job_data"
}

# ─── Service Health ──────────────────────────────────────────
services_json() {
    local svcs="["
    local first=true

    if [ -n "$FORWARD_PORTS" ]; then
        IFS=',' read -ra PAIRS <<< "$FORWARD_PORTS"
        for pair in "${PAIRS[@]}"; do
            lp=$(echo "$pair" | cut -d: -f1)
            rp=$(echo "$pair" | cut -d: -f2)

            local healthy=false name="port-${rp}" svc_type="unknown" detail="{}"

            # Try health endpoint
            local health=$(curl -sf --max-time 3 "http://localhost:${lp}/health" 2>/dev/null)
            if [ -n "$health" ]; then
                healthy=true
                name=$(echo "$health" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("model",d.get("status","unknown")))' 2>/dev/null || echo "unknown")
                svc_type="health"
                detail="$health"
            fi

            if [ "$healthy" = false ]; then
                # Try OpenAI models endpoint (with and without auth)
                local models=$(curl -sf --max-time 3 "http://localhost:${lp}/v1/models" 2>/dev/null)
                [ -z "$models" ] && models=$(curl -sf --max-time 3 -H "Authorization: Bearer ${API_KEY:-token}" "http://localhost:${lp}/v1/models" 2>/dev/null)
                if [ -n "$models" ]; then
                    healthy=true
                    name=$(echo "$models" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d["data"][0]["id"])' 2>/dev/null || echo "unknown")
                    svc_type="openai"
                    detail="$models"
                fi
            fi

            $first || svcs+=","
            svcs+=$(printf '{"port":%d,"remote_port":%d,"healthy":%s,"name":"%s","type":"%s"}' \
                "$lp" "$rp" "$healthy" "$name" "$svc_type")
            first=false
        done
    fi

    svcs+="]"
    echo "$svcs"
}

# ─── Main ────────────────────────────────────────────────────
case "${1:-}" in
    --vpn)      vpn_json; echo ;;
    --tunnel)   tunnel_json; echo ;;
    --job)      job_json ;;
    --services) services_json ;;
    --help|-h)
        cat << 'EOF'
hpc-status — Machine-readable HPC status (JSON output)

USAGE:
    hpc-status              Full status
    hpc-status --vpn        VPN status
    hpc-status --tunnel     Tunnel status
    hpc-status --job        SLURM job info
    hpc-status --services   Service health checks
EOF
        ;;
    *)
        # Full status
        vpn=$(vpn_json)
        tunnel=$(tunnel_json)
        job=$(job_json)
        services=$(services_json)

        printf '{"vpn":%s,"tunnel":%s,"job":%s,"services":%s}\n' \
            "$vpn" "$tunnel" "$job" "$services"
        ;;
esac
