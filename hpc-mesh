#!/bin/bash
# hpc-mesh — SSH mesh network between machines
# Like Tailscale but with SSH tunnels. No accounts, no signups.
#
# Usage:
#   hpc-mesh add <name> <user@host> [--cloudflare|--proxy CMD|--jump HOST]
#   hpc-mesh remove <name>
#   hpc-mesh sync                  Cross-deploy keys between all peers
#   hpc-mesh share <port> [name]   Expose a local port to peers (or specific peer)
#   hpc-mesh unshare <port>        Stop sharing a port
#   hpc-mesh connect [name]        Start tunnels to peer (or all peers)
#   hpc-mesh disconnect [name]     Stop tunnels
#   hpc-mesh status                Full mesh status (JSON-friendly)
#   hpc-mesh list                  List peers
#   hpc-mesh ssh <name> [cmd]      SSH to a peer
#   hpc-mesh deploy <name>         Deploy hpc-mesh to a peer
#   hpc-mesh topology              Visual network map

set -o pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

MESH_DIR="$HOME/.config/hpc-mesh"
SYSTEMD_DIR="$HOME/.config/systemd/user"
BIN_DIR="$HOME/.local/bin"
MESH_KEY="$HOME/.ssh/hpc-mesh"
MY_NAME=""

ok()   { echo -e "  ${GREEN}✓${NC} $1"; }
fail() { echo -e "  ${RED}✗${NC} $1"; }
warn() { echo -e "  ${YELLOW}!${NC} $1"; }
info() { echo -e "  ${CYAN}→${NC} $1"; }

mkdir -p "$MESH_DIR/peers" "$SYSTEMD_DIR"

# ─── Identity ────────────────────────────────────────────────
init_identity() {
    if [ ! -f "$MESH_DIR/me.conf" ]; then
        local hostname=$(hostname -s)
        echo -en "  ${BOLD}?${NC} Name for this machine [$hostname]: "
        read -r input
        MY_NAME="${input:-$hostname}"
        echo "MY_NAME=$MY_NAME" > "$MESH_DIR/me.conf"
    else
        source "$MESH_DIR/me.conf"
    fi

    # Generate mesh key if needed
    if [ ! -f "$MESH_KEY" ]; then
        info "Generating mesh SSH key..."
        ssh-keygen -t ed25519 -f "$MESH_KEY" -N "" -C "mesh:${MY_NAME}" -q
        ok "Key: $MESH_KEY"
    fi

    # Ensure own key is in authorized_keys
    local pub=$(cat "${MESH_KEY}.pub")
    mkdir -p "$HOME/.ssh"
    grep -qF "$pub" "$HOME/.ssh/authorized_keys" 2>/dev/null || \
        echo "$pub" >> "$HOME/.ssh/authorized_keys"
}

# ─── Peer config helpers ─────────────────────────────────────
peer_conf() { echo "$MESH_DIR/peers/${1}.conf"; }

load_peer() {
    local conf=$(peer_conf "$1")
    if [ ! -f "$conf" ]; then
        fail "Peer '$1' not found"
        return 1
    fi
    source "$conf"
}

ssh_cmd_for_peer() {
    # Build SSH command for a peer
    local name="$1"
    load_peer "$name" || return 1
    local cmd="ssh -o ConnectTimeout=15 -o BatchMode=yes -i $MESH_KEY"
    [ -n "$PEER_PORT" ] && [ "$PEER_PORT" != "22" ] && cmd="$cmd -p $PEER_PORT"
    [ -n "$PEER_PROXY" ] && cmd="$cmd -o ProxyCommand='$PEER_PROXY'"
    [ -n "$PEER_JUMP" ] && cmd="$cmd -o ProxyJump=$PEER_JUMP"
    cmd="$cmd ${PEER_USER}@${PEER_HOST}"
    echo "$cmd"
}

# ─── Add peer ────────────────────────────────────────────────
cmd_add() {
    local name="$1"; shift
    local userhost="$1"; shift

    if [ -z "$name" ] || [ -z "$userhost" ]; then
        echo "Usage: hpc-mesh add <name> <user@host> [--cloudflare|--proxy CMD|--jump HOST|--port N]"
        exit 1
    fi

    init_identity

    local user=$(echo "$userhost" | cut -d@ -f1)
    local host=$(echo "$userhost" | cut -d@ -f2)
    local proxy="" jump="" port="22"

    while [ $# -gt 0 ]; do
        case "$1" in
            --cloudflare|-c)
                local cf=$(command -v cloudflared 2>/dev/null || echo "/usr/local/bin/cloudflared")
                proxy="$cf access ssh --hostname %h"
                ;;
            --proxy|-p)     shift; proxy="$1" ;;
            --jump|-j)      shift; jump="$1" ;;
            --port)         shift; port="$1" ;;
        esac
        shift
    done

    local conf=$(peer_conf "$name")
    cat > "$conf" << EOF
PEER_NAME=$name
PEER_USER=$user
PEER_HOST=$host
PEER_PORT=$port
PEER_PROXY='$proxy'
PEER_JUMP=$jump
PEER_SHARED_PORTS=
EOF

    ok "Peer added: $name ($user@$host)"

    # Copy key to peer
    info "Deploying SSH key to $name..."
    local ssh_opts="-o StrictHostKeyChecking=no -p $port"
    [ -n "$proxy" ] && ssh_opts="$ssh_opts -o ProxyCommand='$proxy'"
    [ -n "$jump" ] && ssh_opts="$ssh_opts -o ProxyJump=$jump"

    # Try passwordless first
    if eval ssh $ssh_opts -o BatchMode=yes -i "$MESH_KEY" "${user}@${host}" "echo ok" >/dev/null 2>&1; then
        ok "Key already authorized on $name"
    else
        # Try with sshpass
        echo -en "  ${BOLD}?${NC} Password for ${user}@${host} (or Enter to skip): "
        read -rs pass
        echo ""
        if [ -n "$pass" ] && command -v sshpass &>/dev/null; then
            eval sshpass -p "'$pass'" ssh-copy-id -i "${MESH_KEY}.pub" $ssh_opts "${user}@${host}" 2>&1 | tail -1
        elif [ -n "$pass" ]; then
            warn "sshpass not installed. Add this key manually:"
            echo -e "  ${YELLOW}$(cat "${MESH_KEY}.pub")${NC}"
            echo -en "  ${BOLD}?${NC} Press Enter when done..."
            read -r
        fi
    fi

    # Test connection
    local cmd=$(ssh_cmd_for_peer "$name")
    if eval $cmd "echo ok" >/dev/null 2>&1; then
        local remote_hostname=$(eval $cmd "hostname -s" 2>/dev/null)
        ok "Connected to $name ($remote_hostname)"
    else
        warn "Could not connect to $name — check settings"
    fi
}

# ─── Remove peer ─────────────────────────────────────────────
cmd_remove() {
    local name="$1"
    [ -z "$name" ] && { echo "Usage: hpc-mesh remove <name>"; exit 1; }

    # Stop tunnel
    systemctl --user stop "mesh-${name}" 2>/dev/null
    systemctl --user disable "mesh-${name}" 2>/dev/null
    rm -f "$SYSTEMD_DIR/mesh-${name}.service"
    rm -f "$BIN_DIR/mesh-tunnel-${name}.sh"
    rm -f "$(peer_conf "$name")"
    systemctl --user daemon-reload 2>/dev/null
    ok "Removed peer: $name"
}

# ─── Sync keys across all peers ──────────────────────────────
cmd_sync() {
    init_identity

    local peers=($(ls "$MESH_DIR/peers/"*.conf 2>/dev/null | xargs -I{} basename {} .conf))
    if [ ${#peers[@]} -eq 0 ]; then
        echo "No peers. Add some with: hpc-mesh add <name> <user@host>"
        return
    fi

    echo -e "${BOLD}Collecting keys from all peers...${NC}"

    # Collect all public keys (ours + all peers')
    local ALL_KEYS=$(cat "${MESH_KEY}.pub")

    for peer in "${peers[@]}"; do
        local cmd=$(ssh_cmd_for_peer "$peer")
        local remote_key=$(eval $cmd "cat ~/.ssh/hpc-mesh.pub 2>/dev/null || cat ~/.ssh/id_ed25519.pub 2>/dev/null" 2>/dev/null)
        if [ -n "$remote_key" ]; then
            ALL_KEYS+=$'\n'"$remote_key"
            ok "$peer: key collected"
        else
            warn "$peer: no key found (deploy mesh first: hpc-mesh deploy $peer)"
        fi
    done

    echo ""
    echo -e "${BOLD}Deploying keys to all peers...${NC}"

    # Deploy all keys to all peers
    for peer in "${peers[@]}"; do
        local cmd=$(ssh_cmd_for_peer "$peer")
        echo "$ALL_KEYS" | eval $cmd "bash -c 'mkdir -p ~/.ssh; while IFS= read -r key; do [ -z \"\\\$key\" ] && continue; grep -qF \"\\\$key\" ~/.ssh/authorized_keys 2>/dev/null || echo \"\\\$key\" >> ~/.ssh/authorized_keys; done; chmod 600 ~/.ssh/authorized_keys'" 2>/dev/null
        ok "$peer: keys synced"
    done

    # Also update local
    echo "$ALL_KEYS" | while IFS= read -r key; do
        [ -z "$key" ] && continue
        grep -qF "$key" "$HOME/.ssh/authorized_keys" 2>/dev/null || \
            echo "$key" >> "$HOME/.ssh/authorized_keys"
    done
    ok "local: keys synced"
}

# ─── Share a port ────────────────────────────────────────────
cmd_share() {
    local port="$1"
    local target="${2:-all}"
    [ -z "$port" ] && { echo "Usage: hpc-mesh share <port> [peer|all]"; exit 1; }

    if [ "$target" = "all" ]; then
        local peers=($(ls "$MESH_DIR/peers/"*.conf 2>/dev/null | xargs -I{} basename {} .conf))
        for peer in "${peers[@]}"; do
            _add_shared_port "$peer" "$port"
        done
    else
        _add_shared_port "$target" "$port"
    fi

    ok "Port $port shared. Restart tunnels: hpc-mesh connect"
}

_add_shared_port() {
    local peer="$1" port="$2"
    local conf=$(peer_conf "$peer")
    [ ! -f "$conf" ] && return

    source "$conf"
    if echo "$PEER_SHARED_PORTS" | grep -q "\b${port}\b" 2>/dev/null; then
        return  # already shared
    fi

    if [ -n "$PEER_SHARED_PORTS" ]; then
        PEER_SHARED_PORTS="${PEER_SHARED_PORTS},${port}"
    else
        PEER_SHARED_PORTS="$port"
    fi
    sed -i "s/^PEER_SHARED_PORTS=.*/PEER_SHARED_PORTS=$PEER_SHARED_PORTS/" "$conf"
    info "Port $port shared with $peer"
}

# ─── Unshare a port ──────────────────────────────────────────
cmd_unshare() {
    local port="$1"
    [ -z "$port" ] && { echo "Usage: hpc-mesh unshare <port>"; exit 1; }

    for conf in "$MESH_DIR/peers/"*.conf; do
        [ ! -f "$conf" ] && continue
        source "$conf"
        local new_ports=$(echo "$PEER_SHARED_PORTS" | tr ',' '\n' | grep -v "^${port}$" | paste -sd,)
        sed -i "s/^PEER_SHARED_PORTS=.*/PEER_SHARED_PORTS=$new_ports/" "$conf"
    done
    ok "Port $port unshared from all peers"
}

# ─── Connect tunnels ────────────────────────────────────────
cmd_connect() {
    local target="${1:-all}"
    init_identity

    if [ "$target" = "all" ]; then
        local peers=($(ls "$MESH_DIR/peers/"*.conf 2>/dev/null | xargs -I{} basename {} .conf))
    else
        local peers=("$target")
    fi

    for peer in "${peers[@]}"; do
        _create_tunnel_service "$peer"
        systemctl --user daemon-reload 2>/dev/null
        systemctl --user restart "mesh-${peer}" 2>/dev/null
        sleep 2
        if systemctl --user is-active "mesh-${peer}" >/dev/null 2>&1; then
            ok "$peer: tunnel active"
        else
            warn "$peer: tunnel failed (check: systemctl --user status mesh-${peer})"
        fi
    done
}

_create_tunnel_service() {
    local name="$1"
    local conf=$(peer_conf "$name")
    source "$conf"

    # Build forward args: -R for shared ports (we expose our ports on their machine)
    #                      -L for their shared ports (we pull their ports to localhost)
    local TUNNEL_SCRIPT="$BIN_DIR/mesh-tunnel-${name}.sh"

    cat > "$TUNNEL_SCRIPT" << TEOF
#!/bin/bash
source "$conf"
source "$MESH_DIR/me.conf" 2>/dev/null

FORWARD_ARGS=""

# Our shared ports → remote peer gets them on localhost
if [ -n "\$PEER_SHARED_PORTS" ]; then
    IFS=',' read -ra PORTS <<< "\$PEER_SHARED_PORTS"
    for p in "\${PORTS[@]}"; do
        FORWARD_ARGS="\$FORWARD_ARGS -R \${p}:localhost:\${p}"
    done
fi

# Peer's shared ports → we get them on localhost offset
# Read peer's exports file if it exists
if [ -f "$MESH_DIR/peers/${name}.imports" ]; then
    while IFS=: read -r remote_port local_port; do
        FORWARD_ARGS="\$FORWARD_ARGS -L \${local_port}:localhost:\${remote_port}"
    done < "$MESH_DIR/peers/${name}.imports"
fi

[ -z "\$FORWARD_ARGS" ] && { echo "No ports to forward for $name"; exit 0; }

SSH_CMD="/usr/bin/ssh -N \
    -o ServerAliveInterval=30 \
    -o ServerAliveCountMax=3 \
    -o ExitOnForwardFailure=yes \
    -o ConnectTimeout=15 \
    -o BatchMode=yes \
    -i $MESH_KEY"

[ -n "\$PEER_PORT" ] && [ "\$PEER_PORT" != "22" ] && SSH_CMD="\$SSH_CMD -p \$PEER_PORT"
[ -n "\$PEER_PROXY" ] && SSH_CMD="\$SSH_CMD -o ProxyCommand='\$PEER_PROXY'"
[ -n "\$PEER_JUMP" ] && SSH_CMD="\$SSH_CMD -o ProxyJump=\$PEER_JUMP"

SSH_CMD="\$SSH_CMD \$FORWARD_ARGS \${PEER_USER}@\${PEER_HOST}"
eval exec \$SSH_CMD
TEOF
    chmod +x "$TUNNEL_SCRIPT"

    # Create systemd service
    cat > "$SYSTEMD_DIR/mesh-${name}.service" << SEOF
[Unit]
Description=Mesh tunnel to $name
After=network-online.target

[Service]
Type=simple
ExecStart=$TUNNEL_SCRIPT
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
SEOF
    systemctl --user enable "mesh-${name}" 2>/dev/null
}

# ─── Disconnect ──────────────────────────────────────────────
cmd_disconnect() {
    local target="${1:-all}"

    if [ "$target" = "all" ]; then
        for conf in "$MESH_DIR/peers/"*.conf; do
            [ ! -f "$conf" ] && continue
            local name=$(basename "$conf" .conf)
            systemctl --user stop "mesh-${name}" 2>/dev/null
        done
        ok "All mesh tunnels stopped"
    else
        systemctl --user stop "mesh-${target}" 2>/dev/null
        ok "Tunnel to $target stopped"
    fi
}

# ─── Status ──────────────────────────────────────────────────
cmd_status() {
    init_identity 2>/dev/null
    [ -f "$MESH_DIR/me.conf" ] && source "$MESH_DIR/me.conf"

    local json='{"self":"'${MY_NAME:-$(hostname -s)}'","peers":['
    local first=true

    for conf in "$MESH_DIR/peers/"*.conf; do
        [ ! -f "$conf" ] && continue
        source "$conf"

        local active=false
        systemctl --user is-active "mesh-${PEER_NAME}" >/dev/null 2>&1 && active=true

        local reachable=false
        local cmd=$(ssh_cmd_for_peer "$PEER_NAME" 2>/dev/null)
        if [ -n "$cmd" ]; then
            eval $cmd "echo ok" >/dev/null 2>&1 && reachable=true
        fi

        $first || json+=","
        json+="{\"name\":\"$PEER_NAME\",\"host\":\"$PEER_HOST\",\"user\":\"$PEER_USER\""
        json+=",\"tunnel\":$active,\"reachable\":$reachable"
        json+=",\"shared_ports\":\"$PEER_SHARED_PORTS\""
        [ -n "$PEER_PROXY" ] && json+=",\"proxy\":true" || json+=",\"proxy\":false"
        json+="}"
        first=false
    done

    json+="]}"
    echo "$json" | python3 -m json.tool 2>/dev/null || echo "$json"
}

# ─── List ────────────────────────────────────────────────────
cmd_list() {
    [ -f "$MESH_DIR/me.conf" ] && source "$MESH_DIR/me.conf"
    echo -e "${BOLD}Mesh Network${NC} — ${MY_NAME:-$(hostname -s)}"
    echo -e "${DIM}────────────────────────────────────────${NC}"

    local peers=($(ls "$MESH_DIR/peers/"*.conf 2>/dev/null))
    if [ ${#peers[@]} -eq 0 ]; then
        echo -e "  ${DIM}No peers. Add with: hpc-mesh add <name> <user@host>${NC}"
        return
    fi

    printf "  ${BOLD}%-12s %-25s %-8s %-8s %-15s${NC}\n" "Name" "Host" "Tunnel" "SSH" "Shared Ports"
    echo -e "  ${DIM}──────────── ───────────────────────── ──────── ──────── ───────────────${NC}"

    for conf in "${peers[@]}"; do
        source "$conf"
        local tunnel="down" ssh_ok="?"

        systemctl --user is-active "mesh-${PEER_NAME}" >/dev/null 2>&1 && tunnel="${GREEN}up${NC}"
        [ "$tunnel" = "down" ] && tunnel="${RED}down${NC}"

        local cmd=$(ssh_cmd_for_peer "$PEER_NAME" 2>/dev/null)
        if [ -n "$cmd" ] && eval $cmd "echo ok" >/dev/null 2>&1; then
            ssh_ok="${GREEN}ok${NC}"
        else
            ssh_ok="${RED}fail${NC}"
        fi

        printf "  %-12s %-25s %b      %b      %s\n" \
            "$PEER_NAME" "${PEER_USER}@${PEER_HOST}" "$tunnel" "$ssh_ok" "${PEER_SHARED_PORTS:--}"
    done
    echo ""
}

# ─── SSH to peer ─────────────────────────────────────────────
cmd_ssh() {
    local name="$1"; shift
    [ -z "$name" ] && { echo "Usage: hpc-mesh ssh <name> [command]"; exit 1; }

    local cmd=$(ssh_cmd_for_peer "$name")
    if [ $# -gt 0 ]; then
        eval $cmd "\"$*\""
    else
        # Interactive — drop BatchMode
        cmd=$(echo "$cmd" | sed 's/-o BatchMode=yes//')
        eval $cmd
    fi
}

# ─── Deploy mesh to a peer ───────────────────────────────────
cmd_deploy() {
    local name="$1"
    [ -z "$name" ] && { echo "Usage: hpc-mesh deploy <name>"; exit 1; }

    local cmd=$(ssh_cmd_for_peer "$name")
    info "Deploying hpc-mesh to $name..."

    # Copy the hpc-mesh script
    local scp_cmd=$(echo "$cmd" | sed 's/^ssh /scp /;s/ [^ ]*@/ /;s/[^ ]*$//')
    local peer_user peer_host
    load_peer "$name"

    # Use ssh to pipe the script
    cat "$0" | eval $cmd "cat > ~/.local/bin/hpc-mesh && chmod +x ~/.local/bin/hpc-mesh && mkdir -p ~/.config/hpc-mesh/peers" 2>/dev/null

    # Init identity on remote
    eval $cmd "bash -c '
        mkdir -p ~/.local/bin ~/.config/hpc-mesh/peers ~/.ssh
        if [ ! -f ~/.ssh/hpc-mesh ]; then
            ssh-keygen -t ed25519 -f ~/.ssh/hpc-mesh -N \"\" -C \"mesh:$name\" -q
        fi
        pub=\$(cat ~/.ssh/hpc-mesh.pub)
        grep -qF \"\$pub\" ~/.ssh/authorized_keys 2>/dev/null || echo \"\$pub\" >> ~/.ssh/authorized_keys
        echo \"MY_NAME=$name\" > ~/.config/hpc-mesh/me.conf
        echo \"Mesh identity: $name\"
        # Add PATH
        grep -q \".local/bin\" ~/.bashrc 2>/dev/null || echo \"export PATH=\\\"\\\$HOME/.local/bin:\\\$PATH\\\"\" >> ~/.bashrc
    '" 2>/dev/null

    ok "$name: hpc-mesh deployed"

    # Collect their key
    local remote_pub=$(eval $cmd "cat ~/.ssh/hpc-mesh.pub" 2>/dev/null)
    if [ -n "$remote_pub" ]; then
        grep -qF "$remote_pub" "$HOME/.ssh/authorized_keys" 2>/dev/null || \
            echo "$remote_pub" >> "$HOME/.ssh/authorized_keys"
        ok "$name: key exchanged"
    fi
}

# ─── Topology ────────────────────────────────────────────────
cmd_topology() {
    [ -f "$MESH_DIR/me.conf" ] && source "$MESH_DIR/me.conf"
    local me="${MY_NAME:-$(hostname -s)}"

    echo ""
    echo -e "${BOLD}  Mesh Topology${NC}"
    echo ""

    local peers=($(ls "$MESH_DIR/peers/"*.conf 2>/dev/null | xargs -I{} basename {} .conf))

    if [ ${#peers[@]} -eq 0 ]; then
        echo "  No peers configured."
        return
    fi

    # Center node
    echo -e "                    ${CYAN}┌─────────────┐${NC}"
    echo -e "                    ${CYAN}│${NC}  ${BOLD}${me}${NC}$(printf '%*s' $((10-${#me})) '')${CYAN}│${NC}"
    echo -e "                    ${CYAN}│${NC}  ${DIM}(this node)${NC}  ${CYAN}│${NC}"
    echo -e "                    ${CYAN}└──────┬──────┘${NC}"

    for peer in "${peers[@]}"; do
        source "$(peer_conf "$peer")"
        local status="${RED}●${NC}"
        systemctl --user is-active "mesh-${peer}" >/dev/null 2>&1 && status="${GREEN}●${NC}"

        local conn_type="ssh"
        [ -n "$PEER_PROXY" ] && conn_type="cloudflare"
        [ -n "$PEER_JUMP" ] && conn_type="jump:$PEER_JUMP"

        echo -e "                    ${CYAN}│${NC}"
        printf "              %b─────${CYAN}┤${NC}  ${BOLD}%-10s${NC} %s@%s\n" "$status" "$peer" "$PEER_USER" "$PEER_HOST"
        echo -e "                    ${CYAN}│${NC}    ${DIM}via $conn_type${NC}  ${DIM}ports: ${PEER_SHARED_PORTS:--}${NC}"
    done

    echo -e "                    ${CYAN}│${NC}"
    echo ""
}

# ─── Main ────────────────────────────────────────────────────
case "${1:-}" in
    add)        shift; cmd_add "$@" ;;
    remove|rm)  shift; cmd_remove "$@" ;;
    sync)       cmd_sync ;;
    share)      shift; cmd_share "$@" ;;
    unshare)    shift; cmd_unshare "$@" ;;
    connect|up) shift; cmd_connect "$@" ;;
    disconnect|down) shift; cmd_disconnect "$@" ;;
    status)     cmd_status ;;
    list|ls)    cmd_list ;;
    ssh)        shift; cmd_ssh "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    topology|topo) cmd_topology ;;
    --help|-h|help|"")
        cat << 'EOF'

  hpc-mesh — SSH mesh network

  SETUP:
    hpc-mesh add <name> <user@host> [options]   Add a peer
      --cloudflare, -c    Use Cloudflare Tunnel
      --proxy CMD         Custom ProxyCommand
      --jump HOST         SSH jump host
      --port N            SSH port (default: 22)

    hpc-mesh remove <name>          Remove a peer
    hpc-mesh sync                   Cross-deploy keys (all peers can SSH to each other)
    hpc-mesh deploy <name>          Install hpc-mesh on a peer

  NETWORKING:
    hpc-mesh share <port> [peer]    Expose a local port to peers
    hpc-mesh unshare <port>         Stop sharing a port
    hpc-mesh connect [peer|all]     Start tunnels
    hpc-mesh disconnect [peer|all]  Stop tunnels

  STATUS:
    hpc-mesh list                   List all peers
    hpc-mesh status                 JSON status of all peers
    hpc-mesh topology               Visual network map
    hpc-mesh ssh <name> [cmd]       SSH to a peer

  EXAMPLES:
    hpc-mesh add claw1 yaya@ssh1.campusgenie.ai --cloudflare
    hpc-mesh add hpc aat22g.fsu@hpg.rc.ufl.edu --jump hpg
    hpc-mesh sync
    hpc-mesh share 8080
    hpc-mesh connect
    hpc-mesh topology

EOF
        ;;
    *)
        fail "Unknown command: $1 (try: hpc-mesh --help)"
        exit 1
        ;;
esac
