#!/bin/bash
# hpc-route — Mesh routing daemon with primary/failover HPC origins
# Monitors primary HPC tunnel origin, fails over to backup if it dies.
# Runs as a systemd service on every mesh node.
#
# Architecture:
#   PRIMARY (e.g. home)  ── HPC tunnel ── services on :18080/82/83
#   FAILOVER (e.g. claw3) ── HPC tunnel ready, stopped until needed
#   MESH NODES ── pull from primary via mesh tunnel, switch to failover on failure
#
# Config: ~/.config/hpc-route.conf

set -o pipefail

ROUTE_CONF="$HOME/.config/hpc-route.conf"
MESH_DIR="$HOME/.config/hpc-mesh"

if [ ! -f "$ROUTE_CONF" ]; then
    cat > "$ROUTE_CONF" << 'EOF'
# hpc-route config
# Which mesh peer is the primary HPC tunnel origin?
PRIMARY=home
# Which mesh peer is the failover?
FAILOVER=claw3
# Health check interval (seconds)
CHECK_INTERVAL=30
# How many consecutive failures before failover?
FAIL_THRESHOLD=3
# Ports to check
HEALTH_PORTS=18082
# Am I an origin node? (set to "primary" or "failover" on origin nodes, "client" on others)
MY_ROLE=client
EOF
    echo "Config created: $ROUTE_CONF"
    echo "Edit MY_ROLE, PRIMARY, FAILOVER then run: hpc-route daemon"
    exit 0
fi

source "$ROUTE_CONF"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "[$(date +%H:%M:%S)] ${GREEN}✓${NC} $1"; }
fail() { echo -e "[$(date +%H:%M:%S)] ${RED}✗${NC} $1"; }
warn() { echo -e "[$(date +%H:%M:%S)] ${YELLOW}!${NC} $1"; }

# ─── Health check ────────────────────────────────────────────
check_health() {
    # Check if services are reachable on localhost
    local port="${HEALTH_PORTS%%,*}"
    curl -sf --max-time 3 "http://localhost:${port}/health" >/dev/null 2>&1
}

check_remote_health() {
    local peer="$1"
    local conf="$MESH_DIR/peers/${peer}.conf"
    [ ! -f "$conf" ] && return 1
    source "$conf"

    local ssh_cmd="ssh -o ConnectTimeout=5 -o BatchMode=yes -i $HOME/.ssh/hpc-mesh"
    [ -n "$PEER_PROXY" ] && ssh_cmd="$ssh_cmd -o ProxyCommand='$PEER_PROXY'"
    [ "$PEER_PORT" != "22" ] && ssh_cmd="$ssh_cmd -p $PEER_PORT"
    ssh_cmd="$ssh_cmd ${PEER_USER}@${PEER_HOST}"

    local port="${HEALTH_PORTS%%,*}"
    eval $ssh_cmd "curl -sf --max-time 3 http://localhost:${port}/health" >/dev/null 2>&1
}

# ─── Mesh tunnel to a peer ───────────────────────────────────
get_active_source() {
    # Which peer am I currently pulling from?
    systemctl --user is-active "mesh-${PRIMARY}" >/dev/null 2>&1 && echo "$PRIMARY" && return
    systemctl --user is-active "mesh-${FAILOVER}" >/dev/null 2>&1 && echo "$FAILOVER" && return
    echo "none"
}

switch_to() {
    local target="$1"
    local current=$(get_active_source)

    if [ "$current" = "$target" ]; then
        return 0
    fi

    # Stop current
    if [ "$current" != "none" ]; then
        systemctl --user stop "mesh-${current}" 2>/dev/null
        warn "Stopped mesh tunnel to $current"
    fi

    # Start new
    systemctl --user restart "mesh-${target}" 2>/dev/null
    sleep 3
    if systemctl --user is-active "mesh-${target}" >/dev/null 2>&1; then
        ok "Switched to $target"
        return 0
    else
        fail "Could not connect to $target"
        return 1
    fi
}

# ─── Origin node: manage HPC tunnel ─────────────────────────
origin_activate() {
    systemctl --user restart hpc-tunnel-forward 2>/dev/null
    sleep 5
    systemctl --user is-active hpc-tunnel-forward >/dev/null 2>&1
}

origin_deactivate() {
    systemctl --user stop hpc-tunnel-forward 2>/dev/null
}

# ─── Daemon mode ─────────────────────────────────────────────
run_daemon() {
    local fail_count=0
    local active_source=""

    echo "hpc-route daemon starting (role=$MY_ROLE, primary=$PRIMARY, failover=$FAILOVER)"

    case "$MY_ROLE" in
        primary)
            # I AM the primary — keep HPC tunnel alive
            ok "I am PRIMARY — starting HPC tunnel"
            origin_activate || fail "HPC tunnel failed to start"
            while true; do
                sleep "$CHECK_INTERVAL"
                if ! check_health; then
                    ((fail_count++))
                    warn "Health check failed ($fail_count/$FAIL_THRESHOLD)"
                    if [ "$fail_count" -ge "$FAIL_THRESHOLD" ]; then
                        warn "Restarting HPC tunnel..."
                        origin_activate && fail_count=0 || fail "HPC tunnel restart failed"
                    fi
                else
                    fail_count=0
                fi
            done
            ;;

        failover)
            # I AM the failover — monitor primary, take over if it dies
            ok "I am FAILOVER — monitoring primary ($PRIMARY)"
            origin_deactivate  # stay dormant
            while true; do
                sleep "$CHECK_INTERVAL"
                if check_remote_health "$PRIMARY"; then
                    # Primary is healthy
                    if systemctl --user is-active hpc-tunnel-forward >/dev/null 2>&1; then
                        # We were active, primary recovered — stand down
                        ok "Primary recovered — standing down"
                        origin_deactivate
                    fi
                    fail_count=0
                else
                    ((fail_count++))
                    warn "Primary unhealthy ($fail_count/$FAIL_THRESHOLD)"
                    if [ "$fail_count" -ge "$FAIL_THRESHOLD" ]; then
                        if ! systemctl --user is-active hpc-tunnel-forward >/dev/null 2>&1; then
                            warn "FAILOVER ACTIVATED — taking over from $PRIMARY"
                            origin_activate && ok "Failover HPC tunnel active" || fail "Failover failed"
                        fi
                        fail_count=0
                    fi
                fi
            done
            ;;

        client)
            # I am a client — pull from primary, failover if needed
            ok "I am CLIENT — connecting to primary ($PRIMARY)"
            switch_to "$PRIMARY"
            while true; do
                sleep "$CHECK_INTERVAL"
                if check_health; then
                    fail_count=0
                else
                    ((fail_count++))
                    active=$(get_active_source)
                    warn "Services down via $active ($fail_count/$FAIL_THRESHOLD)"

                    if [ "$fail_count" -ge "$FAIL_THRESHOLD" ]; then
                        if [ "$active" = "$PRIMARY" ] || [ "$active" = "none" ]; then
                            warn "Failing over to $FAILOVER..."
                            switch_to "$FAILOVER" && fail_count=0
                        elif [ "$active" = "$FAILOVER" ]; then
                            warn "Trying primary again..."
                            switch_to "$PRIMARY" && fail_count=0
                        fi
                    fi
                fi
            done
            ;;
    esac
}

# ─── CLI ─────────────────────────────────────────────────────
case "${1:-}" in
    daemon|run)
        run_daemon
        ;;
    status)
        echo -e "${BOLD}Route Status${NC}"
        echo "  Role: $MY_ROLE"
        echo "  Primary: $PRIMARY"
        echo "  Failover: $FAILOVER"
        echo "  Active source: $(get_active_source)"
        echo -n "  Services healthy: "
        check_health && echo -e "${GREEN}yes${NC}" || echo -e "${RED}no${NC}"
        if [ "$MY_ROLE" != "client" ]; then
            echo -n "  HPC tunnel: "
            systemctl --user is-active hpc-tunnel-forward 2>/dev/null || echo "inactive"
        fi
        ;;
    failover)
        warn "Manual failover triggered"
        active=$(get_active_source)
        if [ "$active" = "$PRIMARY" ]; then
            switch_to "$FAILOVER"
        else
            switch_to "$PRIMARY"
        fi
        ;;
    --help|-h|help|"")
        cat << 'EOF'
hpc-route — Mesh routing with primary/failover HPC origins

USAGE:
    hpc-route daemon        Run routing daemon (use via systemd)
    hpc-route status        Show current routing state
    hpc-route failover      Manual failover toggle

CONFIG: ~/.config/hpc-route.conf
    MY_ROLE=client|primary|failover
    PRIMARY=<mesh peer name>
    FAILOVER=<mesh peer name>
    CHECK_INTERVAL=30
    FAIL_THRESHOLD=3
EOF
        ;;
esac
